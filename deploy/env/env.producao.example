# .env.producao — Produção
# Copiar para /opt/retanfactor/.env.producao no servidor.
# Nunca versionar este arquivo com valores reais.
# Proteger com: chmod 600 /opt/retanfactor/.env.producao

# ---------------------------------------------------------------------------
# Identificação do ambiente
# ---------------------------------------------------------------------------
APP_ENV=producao
ESTACAO=RECURTIMENTO

# ---------------------------------------------------------------------------
# Banco de dados SQLite
# ---------------------------------------------------------------------------
# Deixar vazio para usar o caminho padrão: data/fatores_producao.db
SQLITE_DB_PATH=

# ---------------------------------------------------------------------------
# Oracle
# ---------------------------------------------------------------------------
ORACLE_DSN=host:port/service_name
ORACLE_USER=usuario_oracle
ORACLE_PASSWORD=senha_oracle
ORACLE_TIMEOUT_SECONDS=30
