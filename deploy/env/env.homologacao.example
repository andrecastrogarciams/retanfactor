# .env.homologacao — Homologação
# Copiar para /opt/retanfactor/.env.homologacao no servidor.
# Nunca versionar este arquivo com valores reais.
# Proteger com: chmod 600 /opt/retanfactor/.env.homologacao

# ---------------------------------------------------------------------------
# Identificação do ambiente
# ---------------------------------------------------------------------------
# IMPORTANTE: APP_ENV=homologacao ativa:
#   - Banner vermelho de aviso em todas as telas
#   - Desabilitação da exportação PDF (ADR-005)
#   - SQLite próprio separado da produção
APP_ENV=homologacao
ESTACAO=RECURTIMENTO-HML

# ---------------------------------------------------------------------------
# Banco de dados SQLite
# ---------------------------------------------------------------------------
# SQLite separado da produção (AC Story 3.1)
SQLITE_DB_PATH=

# ---------------------------------------------------------------------------
# Oracle
# ---------------------------------------------------------------------------
# ATENÇÃO: homologação usa a mesma base Oracle de produção (ADR-005).
# Evitar operações destrutivas de teste.
ORACLE_DSN=host:port/service_name
ORACLE_USER=usuario_oracle
ORACLE_PASSWORD=senha_oracle
ORACLE_TIMEOUT_SECONDS=30
